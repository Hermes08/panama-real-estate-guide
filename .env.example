# =============================================================================
# panamarealestateguide.com — environment variables template
# =============================================================================
# Copy to .env (gitignored) for local dev, OR add as GitHub Secrets for prod.
# The Netlify deploy workflow reads these and injects matching tracking tags
# into all HTML pages at build time. If a value is empty, that tag is skipped.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Already configured in GitHub Secrets (do NOT need to re-set):
# ─────────────────────────────────────────────────────────────────────────────
# AIRTABLE_TOKEN          (configured · syncs project data on every deploy)
# NETLIFY_AUTH_TOKEN      (configured · used by GH Actions to deploy)
# NETLIFY_SITE_ID         (configured · 8c0755c4-b453-449d-a453-62086ca65681)


# ─────────────────────────────────────────────────────────────────────────────
# Sprint 1 · MANDATORY for ad launch
# Add each of these as a GitHub Secret under repo Settings → Secrets → Actions
# ─────────────────────────────────────────────────────────────────────────────

# Meta (Facebook/Instagram) Pixel + Conversions API
# Get at business.facebook.com → Events Manager → Pixel ID
# CAPI token: Events Manager → Settings → Conversions API → Generate access token
META_PIXEL_ID=
META_CAPI_TOKEN=
META_BUSINESS_MANAGER_ID=

# Google Tag Manager — container ID, format GTM-XXXXXXX
# Get at tagmanager.google.com → New Container
GTM_CONTAINER_ID=

# Google Analytics 4 — measurement ID, format G-XXXXXXXXXX
# Get at analytics.google.com → Property → Data Streams → Web → Measurement ID
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Google Ads — conversion ID, format AW-XXXXXXXXX
# Get at ads.google.com → Tools → Conversions → New conversion
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL_LEAD=
GOOGLE_ADS_CONVERSION_LABEL_WHATSAPP=
GOOGLE_ADS_CONVERSION_LABEL_CALENDLY=

# TikTok Ads Pixel
# Get at ads.tiktok.com → Assets → Events → Web Events
TIKTOK_PIXEL_ID=


# ─────────────────────────────────────────────────────────────────────────────
# Sprint 2 · CRM + scheduling (TBD — pick one CRM)
# ─────────────────────────────────────────────────────────────────────────────

# Option A · GoHighLevel
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_NURTURE_WORKFLOW_ID=

# Option B · HubSpot Free
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=

# Calendly — for booking embed + webhook
CALENDLY_PERSONAL_ACCESS_TOKEN=
CALENDLY_USER_URI=


# ─────────────────────────────────────────────────────────────────────────────
# Optional · email + server-side CAPI hosting
# ─────────────────────────────────────────────────────────────────────────────

# SendGrid (or any transactional email provider)
SENDGRID_API_KEY=
EMAIL_FROM=hello@digitalsecretary.io
EMAIL_REPLY_TO=hello@digitalsecretary.io

# Stape.io — server-side GTM hosting for Meta CAPI
# https://stape.io · ~$10-30/mo · gives you a track.panamarealestateguide.com subdomain
STAPE_CONTAINER_ID=
STAPE_SUBDOMAIN=track.panamarealestateguide.com
